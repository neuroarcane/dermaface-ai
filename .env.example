# Copy to .env and fill in. .env is gitignored.

# Experiment tracking (optional)
WANDB_API_KEY=
WANDB_PROJECT=dermaface-ai

# Where datasets live (defaults to ./data). Override if stored elsewhere.
DERMAFACE_DATA_DIR=

# Path to a trained checkpoint for the app / inference.
# If unset or missing, the app runs in PLACEHOLDER mode (dummy predictions).
DERMAFACE_MODEL_PATH=models/dermaface_best.pt
